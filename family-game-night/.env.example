# ---- Supabase (get these from Supabase Dashboard → Project Settings → API) ----
# Public values (safe to expose to the browser). Both names are read; set the
# NEXT_PUBLIC_* ones for the client, the plain ones are accepted as fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Secret — server only. NEVER expose to the browser. (Settings → API → service_role)
SUPABASE_SERVICE_ROLE=

# Optional: the public origin used to build join links / QR codes.
# On Vercel this is auto-detected; set it only to override.
NEXT_PUBLIC_APP_URL=
