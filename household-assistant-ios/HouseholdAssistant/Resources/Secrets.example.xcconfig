// Copy this file to Secrets.xcconfig and fill in real values.
//   cp Secrets.example.xcconfig Secrets.xcconfig
// Secrets.xcconfig is gitignored and never committed.

// Apple Developer Team ID (Xcode > Settings > Accounts). Leave blank for now if
// you only run on the simulator; required for on-device builds + Siri.
DEVELOPMENT_TEAM =

// Anthropic API key (https://console.anthropic.com). Format: sk-ant-...
CLAUDE_API_KEY =

// ElevenLabs API key (https://elevenlabs.io > Profile > API Key).
ELEVENLABS_API_KEY =

// ElevenLabs voice IDs — one distinct voice per assistant.
// Find IDs in the ElevenLabs Voice Library / "Voices" page.
ELEVENLABS_VOICE_JARVIS =
ELEVENLABS_VOICE_SNARF =
ELEVENLABS_VOICE_SCHOOL =
ELEVENLABS_VOICE_HOME =
